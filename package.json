{
  "name": "multimodel-for-copilot",
  "displayName": "MultiModel for Copilot Chat",
  "description": "Drop DeepSeek V4, MiniMax, and more into Copilot Chat's model picker. Vision, thinking mode, agent tools — zero config, BYOK.",
  "icon": "resources/icon.png",
  "version": "0.6.0",
  "publisher": "Vizards",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vizards/multimodel-for-copilot"
  },
  "engines": {
    "vscode": "^1.116.0",
    "node": ">=24"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "keywords": [
    "deepseek",
    "deepseek v4",
    "deepseek-v4",
    "minimax",
    "copilot",
    "github copilot",
    "copilot chat",
    "vision",
    "byok",
    "language model",
    "thinking",
    "reasoning",
    "multimodel",
    "multi-model",
    "ai",
    "chat"
  ],
  "activationEvents": [
    "onUri",
    "onStartupFinished"
  ],
  "enabledApiProposals": [],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "multimodel",
        "displayName": "MultiModel"
      }
    ],
    "commands": [
      {
        "command": "multimodel-copilot.setApiKey",
        "title": "%multimodel-copilot.command.setApiKey%"
      },
      {
        "command": "multimodel-copilot.getApiKey",
        "title": "%multimodel-copilot.command.getApiKey%"
      },
      {
        "command": "multimodel-copilot.clearApiKey",
        "title": "%multimodel-copilot.command.clearApiKey%"
      },
      {
        "command": "multimodel-copilot.setApiKey.deepseek",
        "title": "%multimodel-copilot.command.setApiKey.deepseek%"
      },
      {
        "command": "multimodel-copilot.clearApiKey.deepseek",
        "title": "%multimodel-copilot.command.clearApiKey.deepseek%"
      },
      {
        "command": "multimodel-copilot.setApiKey.opencode-go",
        "title": "%multimodel-copilot.command.setApiKey.opencode-go%"
      },
      {
        "command": "multimodel-copilot.clearApiKey.opencode-go",
        "title": "%multimodel-copilot.command.clearApiKey.opencode-go%"
      },
      {
        "command": "multimodel-copilot.setApiKey.xiaomi-mimo",
        "title": "%multimodel-copilot.command.setApiKey.xiaomi-mimo%"
      },
      {
        "command": "multimodel-copilot.clearApiKey.xiaomi-mimo",
        "title": "%multimodel-copilot.command.clearApiKey.xiaomi-mimo%"
      },
      {
        "command": "multimodel-copilot.setApiKey.minimaxi",
        "title": "%multimodel-copilot.command.setApiKey.minimaxi%"
      },
      {
        "command": "multimodel-copilot.clearApiKey.minimaxi",
        "title": "%multimodel-copilot.command.clearApiKey.minimaxi%"
      },
      {
        "command": "multimodel-copilot.setVisionModel",
        "title": "%multimodel-copilot.command.setVisionModel%"
      },
      {
        "command": "multimodel-copilot.openSettings",
        "title": "%multimodel-copilot.command.openSettings%"
      },
      {
        "command": "multimodel-copilot.showLogs",
        "title": "%multimodel-copilot.command.showLogs%"
      },
      {
        "command": "multimodel-copilot.openRequestDumpsFolder",
        "title": "%multimodel-copilot.command.openRequestDumpsFolder%"
      }
    ],
    "walkthroughs": [
      {
        "id": "multimodelGettingStarted",
        "title": "%multimodel-copilot.walkthrough.title%",
        "description": "%multimodel-copilot.walkthrough.description%",
        "steps": [
          {
            "id": "setApiKey",
            "title": "%multimodel-copilot.walkthrough.setApiKey.title%",
            "description": "%multimodel-copilot.walkthrough.setApiKey.description%",
            "media": {
              "markdown": "resources/walkthrough/set-api-key.md"
            },
            "completionEvents": [
              "onCommand:multimodel-copilot.setApiKey"
            ]
          },
          {
            "id": "showModels",
            "title": "%multimodel-copilot.walkthrough.showModels.title%",
            "description": "%multimodel-copilot.walkthrough.showModels.description%",
            "media": {
              "markdown": "resources/walkthrough/show-models.md"
            }
          },
          {
            "id": "advancedSettings",
            "title": "%multimodel-copilot.walkthrough.advancedSettings.title%",
            "description": "%multimodel-copilot.walkthrough.advancedSettings.description%",
            "media": {
              "markdown": "resources/walkthrough/advanced-settings.md"
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "%multimodel-copilot.config.title%",
      "properties": {
        "multimodel-copilot.baseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "description": "%multimodel-copilot.config.baseUrl.description%"
        },
        "multimodel-copilot.apiKeys": {
          "type": "object",
          "default": {},
          "description": "%multimodel-copilot.config.apiKeys.description%",
          "additionalProperties": {
            "type": "string"
          },
          "properties": {
            "deepseek": {
              "type": "string",
              "description": "%multimodel-copilot.config.apiKeys.deepseek.description%"
            },
            "opencode-go": {
              "type": "string",
              "description": "%multimodel-copilot.config.apiKeys.opencode-go.description%"
            },
            "xiaomi-mimo": {
              "type": "string",
              "description": "%multimodel-copilot.config.apiKeys.xiaomi-mimo.description%"
            },
            "minimaxi": {
              "type": "string",
              "description": "%multimodel-copilot.config.apiKeys.minimaxi.description%"
            }
          }
        },
        "multimodel-copilot.maxTokens": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "%multimodel-copilot.config.maxTokens.description%"
        },
        "multimodel-copilot.experimental.stabilizeToolList": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%multimodel-copilot.config.experimental.stabilizeToolList.description%",
          "tags": [
            "experimental"
          ]
        },
        "multimodel-copilot.modelIdOverrides": {
          "type": "object",
          "default": {
            "deepseek-v4-flash": "deepseek-v4-flash",
            "deepseek-v4-pro": "deepseek-v4-pro",
            "opencode-go-deepseek-v4-flash": "deepseek-v4-flash",
            "opencode-go-deepseek-v4-pro": "deepseek-v4-pro",
            "opencode-go-mimo-v2.5": "mimo-v2.5",
            "opencode-go-mimo-v2.5-pro": "mimo-v2.5-pro",
            "opencode-go-glm-5.1": "glm-5.1",
            "opencode-go-glm-5": "glm-5",
            "opencode-go-kimi-k2.5": "kimi-k2.5",
            "opencode-go-kimi-k2.6": "kimi-k2.6",
            "opencode-go-minimax-m2.7": "minimax-m2.7",
            "opencode-go-minimax-m2.5": "minimax-m2.5",
            "opencode-go-qwen3.7-max": "qwen3.7-max",
            "opencode-go-qwen3.6-plus": "qwen3.6-plus",
            "xiaomi-mimo-v2.5": "mimo-v2.5",
            "xiaomi-mimo-v2.5-pro": "mimo-v2.5-pro",
            "minimaxi-m3": "MiniMax-M3",
            "minimaxi-m2.7": "MiniMax-M2.7",
            "minimaxi-m2.7-highspeed": "MiniMax-M2.7-highspeed"
          },
          "description": "%multimodel-copilot.config.modelIdOverrides.description%",
          "additionalProperties": {
            "type": "string"
          },
          "properties": {
            "deepseek-v4-flash": {
              "type": "string",
              "description": "%multimodel-copilot.config.modelIdOverrides.deepseek-v4-flash.description%"
            },
            "deepseek-v4-pro": {
              "type": "string",
              "description": "%multimodel-copilot.config.modelIdOverrides.deepseek-v4-pro.description%"
            },
            "opencode-go-deepseek-v4-flash": {
              "type": "string",
              "description": "%multimodel-copilot.config.modelIdOverrides.opencode-go-deepseek-v4-flash.description%"
            },
            "opencode-go-deepseek-v4-pro": {
              "type": "string",
              "description": "%multimodel-copilot.config.modelIdOverrides.opencode-go-deepseek-v4-pro.description%"
            },
            "opencode-go-mimo-v2.5": {
              "type": "string",
              "description": "%multimodel-copilot.config.modelIdOverrides.opencode-go-mimo-v2.5.description%"
            },
            "opencode-go-mimo-v2.5-pro": {
              "type": "string",
              "description": "%multimodel-copilot.config.modelIdOverrides.opencode-go-mimo-v2.5-pro.description%"
            },
            "opencode-go-glm-5.1": {
              "type": "string",
              "description": "%multimodel-copilot.config.modelIdOverrides.opencode-go-glm-5.1.description%"
            },
            "opencode-go-glm-5": {
              "type": "string",
              "description": "%multimodel-copilot.config.modelIdOverrides.opencode-go-glm-5.description%"
            },
            "opencode-go-kimi-k2.5": {
              "type": "string",
              "description": "%multimodel-copilot.config.modelIdOverrides.opencode-go-kimi-k2.5.description%"
            },
            "opencode-go-kimi-k2.6": {
              "type": "string",
              "description": "%multimodel-copilot.config.modelIdOverrides.opencode-go-kimi-k2.6.description%"
            },
            "opencode-go-minimax-m2.7": {
              "type": "string",
              "description": "%multimodel-copilot.config.modelIdOverrides.opencode-go-minimax-m2.7.description%"
            },
            "opencode-go-minimax-m2.5": {
              "type": "string",
              "description": "%multimodel-copilot.config.modelIdOverrides.opencode-go-minimax-m2.5.description%"
            },
            "opencode-go-qwen3.7-max": {
              "type": "string",
              "description": "%multimodel-copilot.config.modelIdOverrides.opencode-go-qwen3.7-max.description%"
            },
            "opencode-go-qwen3.6-plus": {
              "type": "string",
              "description": "%multimodel-copilot.config.modelIdOverrides.opencode-go-qwen3.6-plus.description%"
            },
            "xiaomi-mimo-v2.5": {
              "type": "string",
              "description": "%multimodel-copilot.config.modelIdOverrides.xiaomi-mimo-v2.5.description%"
            },
            "xiaomi-mimo-v2.5-pro": {
              "type": "string",
              "description": "%multimodel-copilot.config.modelIdOverrides.xiaomi-mimo-v2.5-pro.description%"
            },
            "minimaxi-m3": {
              "type": "string",
              "description": "%multimodel-copilot.config.modelIdOverrides.minimaxi-m3.description%"
            },
            "minimaxi-m2.7": {
              "type": "string",
              "description": "%multimodel-copilot.config.modelIdOverrides.minimaxi-m2.7.description%"
            },
            "minimaxi-m2.7-highspeed": {
              "type": "string",
              "description": "%multimodel-copilot.config.modelIdOverrides.minimaxi-m2.7-highspeed.description%"
            }
          }
        },
        "multimodel-copilot.visionModel": {
          "type": "string",
          "default": "",
          "description": "%multimodel-copilot.config.visionModel.description%"
        },
        "multimodel-copilot.visionPrompt": {
          "type": "string",
          "editPresentation": "multilineText",
          "default": "Describe all image attachments in this message.\n\nIf there is one image, describe it directly.\nIf there are multiple images:\n1. Describe each image separately, preserving their order.\n2. Then provide a combined description explaining the overall context and relationships across the images.\n\nReturn one concise factual description suitable for inserting into a text-only chat prompt. Include visible text, objects, UI elements, people, and relevant context. Do not invent details.",
          "description": "%multimodel-copilot.config.visionPrompt.description%"
        },
        "multimodel-copilot.debugMode": {
          "type": "string",
          "default": "minimal",
          "enum": [
            "minimal",
            "metadata",
            "verbose"
          ],
          "enumItemLabels": [
            "%multimodel-copilot.config.debugMode.minimal.label%",
            "%multimodel-copilot.config.debugMode.metadata.label%",
            "%multimodel-copilot.config.debugMode.verbose.label%"
          ],
          "markdownEnumDescriptions": [
            "%multimodel-copilot.config.debugMode.minimal.description%",
            "%multimodel-copilot.config.debugMode.metadata.description%",
            "%multimodel-copilot.config.debugMode.verbose.description%"
          ],
          "markdownDescription": "%multimodel-copilot.config.debugMode.description%"
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('out', { recursive: true, force: true, maxRetries: process.platform === 'win32' ? 10 : 0 })\"",
    "vscode:prepublish": "bash .github/scripts/prepare-marketplace-readme.sh && npm run compile",
    "compile": "npm run clean && tsc -p ./",
    "watch": "npm run clean && tsc -watch -p ./",
    "lint": "oxlint",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/",
    "package": "vsce package --readme-path dist/README.marketplace.md -o dist/",
    "login": "vsce login Vizards"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.116.0",
    "@vscode/vsce": "^3.9.1",
    "ovsx": "0.10.12",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "^6.0.3"
  }
}
